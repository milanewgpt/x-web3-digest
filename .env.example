# Telegram client API (NOT BotFather). Get from https://my.telegram.org
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
# Delivery option A: Telegram Bot API (recommended for forum topics)
# Bot token can also be stored at ~/.hermes/secrets/x_digest_tg_bot_token
TG_BOT_TOKEN=your_bot_token
TG_CHAT_ID=-1003733749773
TG_MESSAGE_THREAD_ID=307

# Delivery option B: Telethon fallback (exact chat/group name or @username)
TG_TARGET=Digest_mi

# X source. v1 supports SocialData API first, cookie fallback is reserved for later.
X_SOURCE=bird_socialdata
SOCIALDATA_KEY=your_socialdata_key
# Optional: one-line file fallback, checked if SOCIALDATA_KEY is empty:
# ~/.openclaw/secrets/socialdata_api_key or ~/.hermes/secrets/socialdata_api_key

# Accounts source: YAML is preferred. X_ACCOUNTS is fallback comma-separated list.
ACCOUNTS_FILE=accounts.yaml
X_ACCOUNTS=polymarket,Kalshi,shayne_coplan

# SQLite DB path (use /data/... with Railway Volume)
DB_PATH=/data/x_digest.sqlite3

# Collection/filtering
EXCLUDE_REPLIES=true
EXCLUDE_RETWEETS=true
PAGES_PER_ACCOUNT=1
REQUEST_TIMEOUT=25

# Digest schedule
SEND_HOURS=8,11,14,19
TZ_DIGEST=Asia/Jerusalem
MAX_ITEMS=12
MAX_CHARS_PER_ITEM=300
